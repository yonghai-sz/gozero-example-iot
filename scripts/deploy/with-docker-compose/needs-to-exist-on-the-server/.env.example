#
# Copy to .env on the server (same directory as docker-compose.prod.yml)
#
#   cp needs-to-exist-on-the-server/.env.example needs-to-exist-on-the-server/.env
#   vim needs-to-exist-on-the-server/.env
#

# --- MySQL (required) ---
MYSQL_DATABASE=myexampledb
MYSQL_ROOT_PASSWORD=change-me


# --- MongoDB (required if using mongo service) ---
MONGO_INITDB_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change-me


# --- Host ports (optional) ---
MYSQL_PORT=3307
REDIS_PORT=6379
ETCD_PORT=2379
MONGO_PORT=27017

SHORTURL_API_PORT=8080

# --- EMQX (optional host ports) ---
EMQX_MQTT_PORT=1883
EMQX_WS_PORT=8083
EMQX_DASHBOARD_PORT=18083

