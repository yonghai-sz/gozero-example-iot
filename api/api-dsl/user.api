syntax = "v1"

import "base.api"

type UserInfo {
	Id   int64  `path:"id"`
	Name string `json:"name"`
	Age  int    `json:"age"`
}

type (
	UserInfoReq {
		Id int64 `path:"id"`
	}
	UserInfoResp {
		Base
		Data UserInfo `json:"data"`
	}
)

type (
	UserInfoUpdateReq {
		Id int64 `json:"id"`
		UserInfo
	}
	UserInfoUpdateResp {
		Base
	}
)

