/bin/
/dist/
*.exe
*.dll
*.so
*.dylib

# Go workspace (local multi-module layout; not used by these Dockerfiles)
go.work
go.work.sum

# Vendored deps — image runs `go mod download` instead
vendor/

# Test files
*_test.go
*.test
coverage.out
coverage.*
*.coverprofile
profile.cov

# Documentation
*.md
docs/

# Development files
docker-compose*.yml
scripts/

# Logs
*.log

# Environment files
.env
.env.*

# Temporary files
tmp/
temp/
*.tmp