# Version control
.git/
.gitignore
.gitmodules

# CI and local tooling (not needed inside the image build context)
.github/
.cursor/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

